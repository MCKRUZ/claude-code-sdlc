    },
    "starter": {
      "description": "Minimal profile, no compliance, quick start for any stack",
      "source": "profiles/starter"
    }
  },
  "hooks": [
    "hooks/sdlc-session-start.ps1",
    "hooks/sdlc-phase-inject.ps1"
  ],
  "scripts": {
    "runtime": "uv",
    "root": "scripts/"
  }
