  "category": "sdlc",
  "skills": "SKILL.md",
  "commands": "commands/",
  "agents": "agents/",
  "keywords": [
    "sdlc",
    "lifecycle",
    "compliance",
    "quality",
    "orchestration",
    "enterprise",
    "azure",
    "dotnet",
    "angular"
  ],
  "profiles": {
