      "description": "C#/.NET 8 + Angular 17 + Azure + SOC 2 compliance",
      "source": "profiles/microsoft-enterprise",
      "skills": [
        "azure-entra-auth",
        "azure-app-service",
        "azure-sql",
        "azure-key-vault",
        "azure-app-insights"
