# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/

# The plugin ships a phase-templates directory literally named "build/" (the Build loop).
# The Python `build/` rule above must not swallow it.
!templates/phases/build/
!templates/phases/build/**

# uv
.uv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test artifacts
/tmp/
*.log

# Do not ignore .sdlc/ — it's part of the plugin's test data
# Target projects will have their own .gitignore
